# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
.output/

# ─── Cloudflare / Wrangler ────────────────────────────────────────────────────
.wrangler/           # local D1 state, miniflare cache — never commit
.dev.vars            # local secrets (JWT_SECRET, REFRESH_SECRET)
.dev.vars.*

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
# Keep .env.example (documents required variables, contains no real values)
!.env.example
!**/.env.example

# ─── Secrets / credentials ────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.*
*secrets*
credentials.*

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Test / coverage ──────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.idea/
.vscode/settings.json

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.local
*.tsbuildinfo
